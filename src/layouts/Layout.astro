---
export interface Props {
  title: string;
  description?: string;
}

import '../styles/globals.css';
import Navigation from '../components/Navigation.astro';
import ContentBarLeft from '../components/ui/ContentBarLeft.astro';
import ContentBarRight from '../components/ui/ContentBarRight.astro';
import Footer from '../components/Footer.astro';
import PageLoader from '../components/PageLoader.astro';
import { SEO } from 'astro-seo';
const { title } = Astro.props;
const { description } = Astro.props; 

---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <!-- Intro loader: first full navigate only (per tab session) -->
    <script is:inline>
      try {
        if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
          var navEntry = performance.getEntriesByType("navigation")[0];
          var navType = navEntry && navEntry.type ? navEntry.type : "navigate";
          var introDone = sessionStorage.getItem("rw-intro-completed") === "1";
          var skipIntro = navType !== "navigate" || introDone;
          if (!skipIntro) {
            document.documentElement.classList.add("page-loader-active");
          }
        }
      } catch (e) {}
    </script>
    <script is:inline>
      window.whenPageRevealed = function (fn) {
        if (typeof fn !== "function") return;
        if (document.documentElement.classList.contains("page-loader-active")) {
          document.addEventListener(
            "rw-page-loader-dismissed",
            function onReady() {
              document.removeEventListener("rw-page-loader-dismissed", onReady);
              fn();
            }
          );
          return;
        }
        if (document.readyState === "loading") {
          document.addEventListener(
            "DOMContentLoaded",
            function onDcl() {
              document.removeEventListener("DOMContentLoaded", onDcl);
              fn();
            }
          );
        } else {
          requestAnimationFrame(function () {
            fn();
          });
        }
      };
    </script>
    <link rel="icon" type="image/x-icon" href="favicon.ico">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.webp">
    <link rel="icon" type="image/webp" sizes="32x32" href="/favicon-32x32.webp">
    <link rel="icon" type="image/webp" sizes="16x16" href="/favicon-16x16.webp">
    <link rel="manifest" href="/site.webmanifest">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Exo+2:wght@500;600&family=JetBrains+Mono:wght@400;600;700&family=Orbitron:wght@500;700&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Exo+2:wght@500;600&family=JetBrains+Mono:wght@400;600;700&family=Orbitron:wght@500;700&display=swap"
      />
    </noscript>
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <SEO
      title={title}
      description={description}
      openGraph={{
        basic: {
          title: "Solutions Architect & Developer based out of Des Moines, IA. Blogs, tutorials, technical insights, project showcases, portfolio and more.",
          type: "",
          image: "",
        }
      }}
      twitter={{
        creator: "@siltrace_"
      }}
      extend={{
        
        link: [{ rel: "icon", href: "/favicon.ico" }],
        
        meta: [
          {
            name: "twitter:image",
            content: "https://x.com/siltrace_/photo",
          },
          { name: "twitter:title", content: "siltrace" },
          { name: "twitter:description", content: "Cybersecurity | Developer" },
        ],
      }}
    />
    <title>{title}</title>
    <slot name="head" />
  </head>
  
  <body class="bg-[#0a0a0a] overflow-x-hidden">
    <PageLoader />
    <div id="documentContainer" class="max-w-2xl md:max-w-5xl h-full glow-grey mx-auto border-l border-r border-[#0a0a0a]/20 ">
      <!-- <ContentBarLeft/> -->
      <!-- <ContentBarRight/> -->
      <Navigation />
      <main id="main-content">
        <slot />
        
      </main>
      <Footer/>
    </div>
    <script>
      import { guardAgainstPathTraversal } from "@/lib/pathTraversal";

      guardAgainstPathTraversal();
      document.addEventListener("astro:page-load", guardAgainstPathTraversal);
    </script>
    <script is:inline>
      (function () {
        function initScrollReveal() {
          if (document.documentElement.classList.contains("page-loader-active")) return;
          var root = document.getElementById("main-content");
          if (!root) return;
          var reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
          var revealTargets = root.querySelectorAll(
            "section:not(#hero), article, .project-card, .blog-card, .education-card, .experience-card, .contact-info-card"
          );
          var titleTargets = root.querySelectorAll(
            ".about-title, .skills-title, .experience-title, .education-title, .projects-title, .blog-title, .contact-title"
          );
          if (reduced) {
            revealTargets.forEach(function (el) { el.classList.add("scroll-reveal-visible"); });
            titleTargets.forEach(function (el) { el.classList.add("scroll-reveal-visible"); });
            return;
          }
          var observer = new IntersectionObserver(
            function (entries) {
              entries.forEach(function (entry) {
                if (!entry.isIntersecting) return;
                entry.target.classList.add("scroll-reveal-visible");
                observer.unobserve(entry.target);
              });
            },
            { threshold: 0.12, rootMargin: "0px 0px -8% 0px" }
          );
          revealTargets.forEach(function (el, i) {
            var noStagger = Boolean(el.closest(".experience-container"));
            el.classList.add("scroll-reveal");
            if (!noStagger) el.style.setProperty("--reveal-delay", Math.min(i * 20, 120) + "ms");
            observer.observe(el);
          });
          titleTargets.forEach(function (el) {
            el.classList.add("scroll-reveal", "scroll-reveal-title");
            observer.observe(el);
          });
          var hero = root.querySelector("#hero");
          if (hero) {
            hero.querySelectorAll(".hero-cta").forEach(function (cta, i) {
              cta.classList.add("scroll-reveal", "hero-cta-reveal");
              cta.style.setProperty("--reveal-delay", 720 + i * 80 + "ms");
              requestAnimationFrame(function () { cta.classList.add("scroll-reveal-visible"); });
            });
          }
        }
        function boot() { initScrollReveal(); }
        if (typeof window.whenPageRevealed === "function") {
          window.whenPageRevealed(boot);
        } else {
          boot();
        }
        document.addEventListener("astro:page-load", boot);
      })();
    </script>
    <script is:inline>
      window.addEventListener("load", function () {
        var s = document.createElement("script");
        s.async = true;
        s.src = "https://www.googletagmanager.com/gtag/js?id=G-NGYM6LNFJM";
        document.head.appendChild(s);
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        window.gtag = gtag;
        gtag("js", new Date());
        gtag("config", "G-NGYM6LNFJM");
        var a = document.createElement("script");
        a.async = true;
        a.defer = true;
        a.src = "https://scripts.simpleanalyticscdn.com/latest.js";
        document.body.appendChild(a);
      }, { once: true });
    </script>
    <noscript><img src="https://queue.simpleanalyticscdn.com/noscript.gif" alt="" referrerpolicy="no-referrer-when-downgrade" /></noscript>
  </body>
</html>
