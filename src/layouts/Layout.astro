---
export interface Props {
  title: string;
  description?: string;
}

import { ClientRouter } from 'astro:transitions';

import '../styles/globals.css';
import Navigation from '../components/Navigation.astro';
import ContentBarLeft from '../components/ui/ContentBarLeft.astro';
import ContentBarRight from '../components/ui/ContentBarRight.astro';
import Footer from '../components/Footer.astro';
import PageLoader from '../components/PageLoader.astro';
import { SEO } from 'astro-seo';
const { title } = Astro.props;
const { description } = Astro.props; 
import { SimpleAnalytics } from 'astro-simpleanalytics-plugin';

---
<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-NGYM6LNFJM"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){ dataLayer.push(arguments); }
  gtag('js', new Date());
  gtag('config', 'G-NGYM6LNFJM');
</script>

    <meta charset="utf-8" />
    <!-- Intro loader: first full navigate only (per tab session) -->
    <script is:inline>
      try {
        if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
          var navEntry = performance.getEntriesByType("navigation")[0];
          var navType = navEntry && navEntry.type ? navEntry.type : "navigate";
          var introDone = sessionStorage.getItem("rw-intro-completed") === "1";
          var skipIntro = navType !== "navigate" || introDone;
          if (!skipIntro) {
            document.documentElement.classList.add("page-loader-active");
          }
        }
      } catch (e) {}
    </script>
    <script is:inline>
      window.whenPageRevealed = function (fn) {
        if (typeof fn !== "function") return;
        if (document.documentElement.classList.contains("page-loader-active")) {
          document.addEventListener(
            "rw-page-loader-dismissed",
            function onReady() {
              document.removeEventListener("rw-page-loader-dismissed", onReady);
              fn();
            }
          );
          return;
        }
        if (document.readyState === "loading") {
          document.addEventListener(
            "DOMContentLoaded",
            function onDcl() {
              document.removeEventListener("DOMContentLoaded", onDcl);
              fn();
            }
          );
        } else {
          requestAnimationFrame(function () {
            fn();
          });
        }
      };
    </script>
    <link rel="icon" type="image/x-icon" href="favicon.ico">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
    <link rel="stylesheet" type='text/css' href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap" rel="stylesheet">


<!-- Testing fonts start -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400..900&display=swap" rel="stylesheet">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Orbitron:wght@400..900&display=swap" rel="stylesheet">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Exo+2:ital,wght@0,100..900;1,100..900&family=Orbitron:wght@400..900&display=swap" rel="stylesheet">
<!-- testing fonts end -->
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <SEO
      title={title}
      description={description}
      openGraph={{
        basic: {
          title: "Solutions Architect & Developer based out of Des Moines, IA. Blogs, tutorials, technical insights, project showcases, portfolio and more.",
          type: "",
          image: "",
        }
      }}
      twitter={{
        creator: "@siltrace_"
      }}
      extend={{
        
        link: [{ rel: "icon", href: "/favicon.ico" }],
        
        meta: [
          {
            name: "twitter:image",
            content: "https://x.com/siltrace_/photo",
          },
          { name: "twitter:title", content: "siltrace" },
          { name: "twitter:description", content: "Cybersecurity | Developer" },
        ],
      }}
    />
    <title>{title}</title>
    <ClientRouter />
    
    <script src="https://code.iconify.design/iconify-icon/3.0.0/iconify-icon.min.js"></script>
    
  </head>
  
  <body class="bg-[#0a0a0a] overflow-x-hidden">
    <PageLoader />
    <div id="documentContainer" class="max-w-2xl md:max-w-5xl h-full glow-grey mx-auto border-l border-r border-[#0a0a0a]/20 ">
      <!-- <ContentBarLeft/> -->
      <!-- <ContentBarRight/> -->
      <Navigation />
      <main id="main-content">
        <slot />
        
      </main>
      <Footer/>
    </div>
    <script>
      import gsap from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(ScrollTrigger);

      function initGsapScrollEffects() {
        if (document.documentElement.classList.contains("page-loader-active")) return;

        const root = document.getElementById("main-content");
        if (!root) return;

        // Reset previous triggers on Astro view transitions before rebuilding.
        ScrollTrigger.getAll().forEach((trigger) => trigger.kill());

        const revealTargets = root.querySelectorAll<HTMLElement>(
          "section:not(#hero), article, .project-card, .blog-card, .education-card, .experience-card, .contact-info-card",
        );

        revealTargets.forEach((el, i) => {
          const noStagger = Boolean(el.closest(".experience-container"));
          gsap.fromTo(
            el,
            { opacity: 0, y: 24, filter: "blur(4px)" },
            {
              opacity: 1,
              y: 0,
              filter: "blur(0px)",
              duration: 0.65,
              delay: noStagger ? 0 : Math.min(i * 0.02, 0.12),
              ease: "power2.out",
              overwrite: "auto",
              scrollTrigger: {
                trigger: el,
                start: "top 86%",
                once: true,
              },
            },
          );
        });

        const titleTargets = root.querySelectorAll<HTMLElement>(
          ".about-title, .skills-title, .experience-title, .education-title, .projects-title, .blog-title, .contact-title",
        );

        titleTargets.forEach((el) => {
          gsap.fromTo(
            el,
            { y: 18, opacity: 0.86 },
            {
              y: 0,
              opacity: 1,
              duration: 0.7,
              ease: "power2.out",
              scrollTrigger: {
                trigger: el,
                start: "top 88%",
                once: true,
              },
            },
          );
        });

        const sectionParallax = root.querySelectorAll<HTMLElement>(
          "#projects, #blog, #contact, #about, #skills",
        );

        sectionParallax.forEach((section) => {
          gsap.to(section, {
            yPercent: -3,
            ease: "none",
            scrollTrigger: {
              trigger: section,
              start: "top bottom",
              end: "bottom top",
              scrub: 0.45,
            },
          });
        });
      }

      const onPageRevealed = (window as any).whenPageRevealed;
      if (typeof onPageRevealed === "function") {
        onPageRevealed(initGsapScrollEffects);
      } else {
        initGsapScrollEffects();
      }
      document.addEventListener("astro:page-load", initGsapScrollEffects);
    </script>
    <SimpleAnalytics />
  </body>
</html>
