---
export interface Props {
  title: string;
  description?: string;
}

import '../styles/globals.css';
import Navigation from '@/components/layout/Navigation.astro';
import Footer from '@/components/layout/Footer.astro';
import { SEO } from 'astro-seo';
const { title } = Astro.props;
const { description } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/x-icon" href="favicon.ico">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.webp">
    <link rel="icon" type="image/webp" sizes="32x32" href="/favicon-32x32.webp">
    <link rel="icon" type="image/webp" sizes="16x16" href="/favicon-16x16.webp">
    <link rel="manifest" href="/site.webmanifest">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Exo+2:wght@500;600&family=JetBrains+Mono:wght@400;600;700&family=Orbitron:wght@500;700&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Exo+2:wght@500;600&family=JetBrains+Mono:wght@400;600;700&family=Orbitron:wght@500;700&display=swap"
      />
    </noscript>
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <SEO
      title={title}
      description={description}
      openGraph={{
        basic: {
          title: "Senior Infrastructure Engineer & Developer based out of Des Moines, IA",
          type: "",
          image: "",
        }
      }}
      twitter={{
        creator: "@siltrace_"
      }}
      extend={{
        link: [{ rel: "icon", href: "/favicon.ico" }],
        meta: [
          {
            name: "twitter:image",
            content: "https://x.com/siltrace_/photo",
          },
          { name: "twitter:title", content: "siltrace" },
          { name: "twitter:description", content: "Cybersecurity | Developer" },
        ],
      }}
    />
    <title>{title}</title>
    <slot name="head" />
  </head>

  <body class="bg-[#0a0a0a] overflow-x-hidden">
    <div id="documentContainer" class="max-w-2xl md:max-w-5xl h-full glow-grey mx-auto border-l border-r border-[#0a0a0a]/20 ">
      <Navigation />
      <main id="main-content">
        <slot />
      </main>
      <Footer/>
    </div>
    <script>
      import { guardAgainstPathTraversal } from "@/lib/pathTraversal";

      guardAgainstPathTraversal();
      document.addEventListener("astro:page-load", guardAgainstPathTraversal);
    </script>
    <script is:inline>
      (function () {
        function initScrollReveal() {
          var root = document.getElementById("main-content");
          if (!root) return;
          var reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
          var revealTargets = root.querySelectorAll(
            "section:not(#hero), article:not(.project-detail):not(.blog-post), .project-card, .blog-card, .education-card, .experience-card, .contact-info-card"
          );
          var titleTargets = root.querySelectorAll(
            ".about-title, .skills-title, .experience-title, .education-title, .projects-title, .blog-title, .contact-title"
          );
          if (reduced) {
            revealTargets.forEach(function (el) { el.classList.add("scroll-reveal-visible"); });
            titleTargets.forEach(function (el) { el.classList.add("scroll-reveal-visible"); });
            return;
          }
          var observer = new IntersectionObserver(
            function (entries) {
              entries.forEach(function (entry) {
                if (!entry.isIntersecting) return;
                entry.target.classList.add("scroll-reveal-visible");
                observer.unobserve(entry.target);
              });
            },
            { threshold: 0.12, rootMargin: "0px 0px -8% 0px" }
          );
          revealTargets.forEach(function (el, i) {
            var noStagger = Boolean(el.closest(".experience-container"));
            el.classList.add("scroll-reveal");
            if (!noStagger) el.style.setProperty("--reveal-delay", Math.min(i * 20, 120) + "ms");
            observer.observe(el);
          });
          titleTargets.forEach(function (el) {
            el.classList.add("scroll-reveal", "scroll-reveal-title");
            observer.observe(el);
          });
          var hero = root.querySelector("#hero");
          if (hero) {
            hero.querySelectorAll(".hero-cta").forEach(function (cta, i) {
              cta.classList.add("scroll-reveal", "hero-cta-reveal");
              cta.style.setProperty("--reveal-delay", 720 + i * 80 + "ms");
              requestAnimationFrame(function () { cta.classList.add("scroll-reveal-visible"); });
            });
          }
        }
        initScrollReveal();
        document.addEventListener("astro:page-load", initScrollReveal);

        function initSectionReveal() {
          var reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
          var opts = { threshold: 0.1, rootMargin: "0px 0px -50px 0px" };
          document.querySelectorAll(".projects-container, .blog-container, .contact-container").forEach(function (el) {
            if (el.classList.contains("in-view") || el.dataset.sectionRevealBound === "1") return;
            el.dataset.sectionRevealBound = "1";
            if (reduced) {
              el.classList.add("in-view");
              return;
            }
            var obs = new IntersectionObserver(function (entries) {
              entries.forEach(function (entry) {
                if (!entry.isIntersecting) return;
                entry.target.classList.add("in-view");
                obs.unobserve(entry.target);
              });
            }, opts);
            obs.observe(el);
          });
        }
        initSectionReveal();
        document.addEventListener("astro:page-load", initSectionReveal);
      })();
    </script>
    <script is:inline>
      window.addEventListener("load", function () {
        var s = document.createElement("script");
        s.async = true;
        s.src = "https://www.googletagmanager.com/gtag/js?id=G-NGYM6LNFJM";
        document.head.appendChild(s);
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        window.gtag = gtag;
        gtag("js", new Date());
        gtag("config", "G-NGYM6LNFJM");
        var a = document.createElement("script");
        a.async = true;
        a.defer = true;
        a.src = "https://scripts.simpleanalyticscdn.com/latest.js";
        document.body.appendChild(a);
      }, { once: true });
    </script>
    <noscript><img src="https://queue.simpleanalyticscdn.com/noscript.gif" alt="" referrerpolicy="no-referrer-when-downgrade" /></noscript>
  </body>
</html>
