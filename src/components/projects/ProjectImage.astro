---
import { Image } from 'astro:assets';
import { resolveProjectImage } from '@/lib/projectImages';

interface Props {
  src: string;
  alt: string;
  class?: string;
  loading?: 'lazy' | 'eager';
  variant?: 'card' | 'hero';
}

const {
  src,
  alt,
  class: className = '',
  loading = 'lazy',
  variant = 'card',
} = Astro.props;

const image = resolveProjectImage(src);
const widths = variant === 'hero' ? [640, 960, 1280] : [352, 704];
const sizes =
  variant === 'hero'
    ? '(max-width: 768px) 100vw, 960px'
    : '(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 352px';
---

{image ? (
  <Image
    src={image}
    alt={alt}
    widths={widths}
    sizes={sizes}
    class={className}
    loading={loading}
  />
) : (
  <img src={src} alt={alt} class={className} loading={loading} decoding="async" />
)}
