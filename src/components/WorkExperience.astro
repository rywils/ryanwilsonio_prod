---
import { experiences } from "src/data/experiences.ts"
---

<script src="https://unpkg.com/alpinejs" defer></script>

<section class="mt-4 experience-container">
  <h2 class="experience-title text-2xl font-bold mb-2 text-(--primary-blue)">Work Experience</h2>
  <div
    class="experience-underline h-0.5 rounded-full bg-gradient-to-r from-(--primary-blue) to-(--primary-purple) mb-8 max-w-[5rem]"
    aria-hidden="true"
  />

  <table class="w-full border-separate border-spacing-y-6">
    <tbody>
      {experiences.map((job, index) => (
        <tr x-data="{ open: false }" class="cursor-pointer group">
          <td colspan="2" class="p-0 align-top" @click="open = !open">
            <div
              class="experience-card rounded-xl px-2 py-1 -mx-2 transition-colors hover:bg-white/[0.03]"
              style={`--exp-delay: ${index * 0.07}s; --exp-direction: ${index % 2 === 0 ? '-28px' : '28px'};`}
            >
              <div class="flex flex-row items-start justify-between gap-4 w-full">
                <div class="flex items-center gap-4 min-w-0">
                  <img
                    src={job.icon.src}
                    alt={job.company}
                    class="h-12 w-12 shrink-0 rounded-full object-contain bg-transparent border-2 border-neutral-800 p-2"
                  />
                  <div class="min-w-0">
                    <div class="font-medium text-[15px] text-(--primary-blue) group-hover:text-(--primary-purple)">{job.title}</div>
                    <div class="text-sm text-neutral-400">{job.company}</div>
                  </div>
                </div>
                <div class="flex items-center justify-end gap-2 shrink-0 text-right whitespace-nowrap text-[14px] pt-0.5">
                  <span class="text-(--primary-blue) group-hover:text-(--primary-purple)">{job.period}</span>
                  <svg
                    x-bind:class="open ? 'rotate-90' : ''"
                    class="h-4 w-4 transition-transform fill-(--primary-blue) group-hover:fill-(--primary-purple)"
                    viewBox="0 0 20 20"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M6.293 4.293a1 1 0 011.414 0L13 9.586a1 1 0 010 1.414l-5.293 5.293a1 1 0 01-1.414-1.414L10.586 10 6.293 5.707a1 1 0 010-1.414z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </div>
              </div>

              <div
                x-show="open"
                x-transition
                class="mt-3 ml-16 text-sm text-neutral-300 leading-relaxed"
              >
                <p>{job.description}</p>
                <ul class="mt-2 space-y-1 list-disc ml-4">
                  {job.achievements.map((a) => (
                    <li>{a}</li>
                  ))}
                </ul>
              </div>
            </div>
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</section>
