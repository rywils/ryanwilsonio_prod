---

---

<canvas id="orbital-tracer" class="pointer-events-none absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 z-50"></canvas>

<script>
(function () {
  const canvas = document.getElementById('orbital-tracer') as HTMLCanvasElement;
  if (!canvas) return;

  const SIZE = 250;
  canvas.width = SIZE;
  canvas.height = SIZE;
  canvas.style.width = SIZE + 'px';
  canvas.style.height = SIZE + 'px';

  const ctx = canvas.getContext('2d')!;
  const cx = SIZE / 2;
  const cy = SIZE / 2;
  const RADIUS = 117;
  
  const icons = [
    { name: 'C',      angle: Math.atan2(-117, 0),   dotColor: '#504bb7', bgColor: '#504bb7' },
    { name: 'Rust',   angle: Math.atan2(-73,  91),  dotColor: '#504bb7', bgColor: '#df372a' },
    { name: 'Python', angle: Math.atan2( 26,  114), dotColor: '#df372a', bgColor: '#ffd94a' },
    { name: 'Go',     angle: Math.atan2( 105,  51), dotColor: '#ffd94a', bgColor: '#00b4e0' },
    { name: 'PHP',    angle: Math.atan2( 105, -51), dotColor: '#00b4e0', bgColor: '#edeef0' },
    { name: 'C#',     angle: Math.atan2( 26, -114), dotColor: '#edeef0', bgColor: '#953cad' },
    { name: 'Elixir', angle: Math.atan2(-73,  -91), dotColor: '#953cad', bgColor: '#2f2a44' },
  ];

  
  const SPEED = (2 * Math.PI) / (16 * 60); 
  const TRAIL_LENGTH = 60; 
  type TrailPoint = { x: number; y: number; age: number };
  const trail: TrailPoint[] = [];

  let dotAngle = icons[0].angle; 
  let currentSegment = 0; 
  const CCW_ORDER = [0, 6, 5, 4, 3, 2, 1]; 

  let segmentIdx = 0; // position in CCW_ORDER
  let currentColor = icons[0].dotColor; 

  // Pop state per icon
  const popState: Record<string, number> = {};
  icons.forEach(ic => popState[ic.name] = 0);

  // Get next icon in CCW_ORDER
  function getNextIconIndex(segIdx: number) {
    return CCW_ORDER[(segIdx + 1) % CCW_ORDER.length];
  }

  function normalizeAngle(a: number) {
    while (a > Math.PI) a -= 2 * Math.PI;
    while (a < -Math.PI) a += 2 * Math.PI;
    return a;
  }

  // Check if dot has passed the target angle (CCW travel = decreasing angle)
  function hasPassedCCW(current: number, target: number, prev: number): boolean {
    const c = normalizeAngle(current);
    const t = normalizeAngle(target);
    const p = normalizeAngle(prev);
    // CCW: angle decreasing. We passed target if prev >= target and current < target
    // But we need to handle wrap-around at -PI/PI boundary
    const diff = normalizeAngle(p - t);
    const diff2 = normalizeAngle(c - t);
    return diff >= 0 && diff2 < 0;
  }

  let prevAngle = dotAngle;
  let nextIconIdx = getNextIconIndex(segmentIdx);

  // Find DOM elements to pop
  function getSkillElements() {
    return document.querySelectorAll<HTMLElement>('.skill');
  }

  function triggerPop(iconName: string) {
    popState[iconName] = 1.0;
    const skills = getSkillElements();
    const nameMap: Record<string, number> = {
      'C': 0, 'Rust': 1, 'Python': 2, 'Go': 3, 'PHP': 4, 'C#': 5, 'Elixir': 6
    };
    const idx = nameMap[iconName];
    if (idx !== undefined && skills[idx]) {
      const el = skills[idx];
      el.style.transition = 'filter 0.08s ease-out, box-shadow 0.08s ease-out';
      el.style.filter = 'brightness(2.5)';
      el.style.boxShadow = `0 0 28px ${icons[idx].bgColor}, 0 0 8px white`;
      setTimeout(() => {
        el.style.filter = '';
        el.style.boxShadow = '';
      }, 350);
    }
  }

  function animate() {
    ctx.clearRect(0, 0, SIZE, SIZE);

    // Move dot CCW (decreasing angle)
    prevAngle = dotAngle;
    dotAngle -= SPEED;
    dotAngle = normalizeAngle(dotAngle);

    // Check if we passed next icon
    const targetAngle = icons[nextIconIdx].angle;
    if (hasPassedCCW(dotAngle, targetAngle, prevAngle)) {
      // Snap to icon
      dotAngle = targetAngle;
      triggerPop(icons[nextIconIdx].name);
      currentColor = icons[nextIconIdx].dotColor;
      segmentIdx = (segmentIdx + 1) % CCW_ORDER.length;
      nextIconIdx = getNextIconIndex(segmentIdx);
    }

    // Dot position
    const dotX = cx + RADIUS * Math.cos(dotAngle);
    const dotY = cy + RADIUS * Math.sin(dotAngle);

    // Add to trail
    trail.push({ x: dotX, y: dotY, age: 0 });
    if (trail.length > TRAIL_LENGTH) trail.shift();

    // Draw trail
    for (let i = 1; i < trail.length; i++) {
      const t0 = trail[i - 1];
      const t1 = trail[i];
      const alpha = (i / trail.length) * 0.7;
      ctx.beginPath();
      ctx.moveTo(t0.x, t0.y);
      ctx.lineTo(t1.x, t1.y);
      ctx.strokeStyle = hexToRgba(currentColor, alpha);
      ctx.lineWidth = 2.5 * (i / trail.length);
      ctx.lineCap = 'round';
      ctx.stroke();
    }

    // Draw dot
    ctx.beginPath();
    ctx.arc(dotX, dotY, 4, 0, Math.PI * 2);
    ctx.fillStyle = '#ffffff';
    ctx.shadowColor = '#ffffff';
    ctx.shadowBlur = 12;
    ctx.fill();
    ctx.shadowBlur = 0;

    // Decay pop states
    Object.keys(popState).forEach(k => {
      if (popState[k] > 0) popState[k] = Math.max(0, popState[k] - 0.04);
    });

    requestAnimationFrame(animate);
  }

  function hexToRgba(hex: string, alpha: number): string {
    const r = parseInt(hex.slice(1, 3), 16);
    const g = parseInt(hex.slice(3, 5), 16);
    const b = parseInt(hex.slice(5, 7), 16);
    return `rgba(${r},${g},${b},${alpha})`;
  }

  // Wait for page load to ensure skill elements are in DOM
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', animate);
  } else {
    animate();
  }
})();
</script>