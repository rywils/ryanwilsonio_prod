---
interface Props {
  class?: string;
  /** Hero homepage card: border draw + soft glow without JS */
  variant?: 'default' | 'hero';
}

const { class: className = '', variant = 'default' } = Astro.props;
const isHero = variant === 'hero';
---

<div class={`glow-card-wrapper ${isHero ? 'glow-card-wrapper--hero' : ''} ${className}`}>
  {isHero && (
    <div class="glow-card-glow" aria-hidden="true"></div>
  )}
  <div class={`glow-card-border ${isHero ? 'glow-card-border--hero' : ''}`}>
    {isHero && (
      <div class="glow-card-edges" aria-hidden="true">
        <span class="glow-card-edge glow-card-edge--top"></span>
        <span class="glow-card-edge glow-card-edge--bottom"></span>
        <span class="glow-card-edge glow-card-edge--left"></span>
        <span class="glow-card-edge glow-card-edge--right"></span>
      </div>
    )}
    <div class="glow-card-content">
      <slot />
    </div>
  </div>
</div>

<style>
  .glow-card-wrapper {
    position: relative;
    isolation: isolate;
  }

  .glow-card-border {
    position: relative;
    padding: 1px;
    border-radius: 0.5rem;
    background: linear-gradient(
      90deg,
      hsl(27deg 93% 60%) 0%,
      hsl(200deg 100% 52%) 25%,
      hsl(280deg 100% 60%) 50%,
      hsl(330deg 100% 52%) 75%,
      hsl(27deg 93% 60%) 100%
    );
    background-size: 200% 100%;
  }

  .glow-card-border--hero {
    border-radius: 0;
    background: transparent;
    padding: 1px;
  }

  .glow-card-glow {
    position: absolute;
    inset: -2px;
    border-radius: 0;
    background: linear-gradient(
      90deg,
      hsl(27deg 93% 60%) 0%,
      hsl(200deg 100% 52%) 25%,
      hsl(280deg 100% 60%) 50%,
      hsl(330deg 100% 52%) 75%,
      hsl(27deg 93% 60%) 100%
    );
    opacity: 0;
    filter: blur(22px);
    z-index: -2;
    pointer-events: none;
    animation: heroGlowIn 1.1s ease-out 0.2s forwards;
  }

  @keyframes heroGlowIn {
    to {
      opacity: 0.55;
    }
  }

  .glow-card-edges {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
  }

  .glow-card-edge {
    position: absolute;
    background: linear-gradient(
      90deg,
      hsl(27deg 93% 60%) 0%,
      hsl(200deg 100% 52%) 25%,
      hsl(280deg 100% 60%) 50%,
      hsl(330deg 100% 52%) 75%,
      hsl(27deg 93% 60%) 100%
    );
    transform-origin: center;
    opacity: 0;
    animation: edgeFadeIn 0.2s ease-out forwards;
  }

  .glow-card-edge--top,
  .glow-card-edge--bottom {
    left: 0;
    right: 0;
    height: 1px;
    transform: scaleX(0);
    animation: edgeScaleX 1.1s ease-out forwards;
  }

  .glow-card-edge--left,
  .glow-card-edge--right {
    top: 0;
    bottom: 0;
    width: 1px;
    transform: scaleY(0);
    animation: edgeScaleY 1s ease-out 0.1s forwards;
  }

  .glow-card-edge--top {
    top: 0;
    animation-delay: 0.25s;
  }

  .glow-card-edge--bottom {
    bottom: 0;
    background: linear-gradient(
      90deg,
      hsl(27deg 93% 60%) 0%,
      hsl(200deg 100% 52%) 25%,
      hsl(280deg 100% 60%) 50%,
      hsl(330deg 100% 52%) 75%,
      hsl(27deg 93% 60%) 100%
    );
    animation-delay: 0.25s;
  }

  .glow-card-edge--left {
    left: 0;
    background: linear-gradient(
      180deg,
      hsl(27deg 93% 60%) 0%,
      hsl(200deg 100% 52%) 25%,
      hsl(280deg 100% 60%) 50%,
      hsl(330deg 100% 52%) 75%,
      hsl(27deg 93% 60%) 100%
    );
    animation-delay: 0.35s;
  }

  .glow-card-edge--right {
    right: 0;
    background: linear-gradient(
      180deg,
      hsl(27deg 93% 60%) 0%,
      hsl(200deg 100% 52%) 25%,
      hsl(280deg 100% 60%) 50%,
      hsl(330deg 100% 52%) 75%,
      hsl(27deg 93% 60%) 100%
    );
    animation-delay: 0.35s;
  }

  @keyframes edgeScaleX {
    20% {
      opacity: 1;
    }
    100% {
      opacity: 1;
      transform: scaleX(1);
    }
  }

  @keyframes edgeScaleY {
    20% {
      opacity: 1;
    }
    100% {
      opacity: 1;
      transform: scaleY(1);
    }
  }

  @keyframes edgeFadeIn {
    to {
      opacity: 1;
    }
  }

  .glow-card-content {
    position: relative;
    background: linear-gradient(135deg, #1e1e24 10%, #050505 60%);
    border-radius: 0.375rem;
    height: 100%;
    width: 100%;
    z-index: 1;
  }

  @media (max-width: 767px) {
    .glow-card-wrapper--hero .glow-card-border--hero {
      overflow: hidden;
    }
  }

  .glow-card-border--hero .glow-card-content {
    border-radius: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .glow-card-glow,
    .glow-card-edge {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
