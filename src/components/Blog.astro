---

import { Calendar, Clock, ArrowRight, User } from '@lucide/astro';
import { getCollection } from 'astro:content';
import CategoryMarker from './ui/CategoryMarker.astro';
import TagBadge from './ui/BlogTagBadge.astro';


const allPosts = await getCollection('blog', ({ data }) => {
  return data.draft !== true;
});


const blogPosts = allPosts.sort((a, b) => {
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});


function getPreview(content: string, wordCount: number = 25): string {
  
  const stripped = content
    .replace(/#{1,6}\s/g, '') 
    .replace(/\*\*|__/g, '') 
    .replace(/\*|_/g, '') 
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1') 
    .replace(/`{1,3}[^`]*`{1,3}/g, '') 
    .replace(/>\s/g, '') 
    .replace(/[-*+]\s/g, '') 
    .trim();
  
  const words = stripped.split(/\s+/);
  if (words.length <= wordCount) {
    return stripped;
  }
  return words.slice(0, wordCount).join(' ') + '...';
}
---

<section id="blog" class="pt-12 pb-16 px-4 sm:px-6 lg:px-8 relative overflow-hidden border-b-1 border-[#10191d] shadow-md shadow-[#0a0a0a]">
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-primary-green/5 to-transparent pointer-events-none"></div>
  
  <div class="max-w-7xl mx-auto relative z-10 blog-container">
    <div class="text-center mb-16">
      <h2 class="text-4xl sm:text-5xl md:text-5xl mb-4 text-[rgb(var(--primary-blue))] blog-title">
        Latest Blog Posts
      </h2>
      <div class="h-[0.8px] w-20 bg-gradient-to-r from-[rgb(var(--primary-purple))] to-[rgb(var(--primary-blue))] mx-auto rounded-full mt-4 blog-underline"></div>
    </div>

    <div class="flex flex-col gap-4 max-w-2xl mx-auto" id="blog-list">
      {blogPosts.slice(0, 6).map((post, index) => (
        <a
          href={`/blog/${post.slug}`}
          class="group rounded-xl overflow-hidden bg-card border border-[rgba(var(--primary-blue),0.20)] hover:border-[rgba(var(--primary-purple),0.50)] transition-all duration-300 ease-out hover:scale-[1.01] block blog-card"
          data-astro-prefetch
          style={`--blog-delay: ${index * 0.1}s`}
        >
          <div class="p-3">
            <div class="flex items-start justify-between gap-4 mb-2">
              <div class="flex flex-wrap gap-1">
                {Array.isArray(post.data.category) ? (
                  post.data.category.map((cat) => (
                      <CategoryMarker label={cat} />
                  ))
                ) : (

                     <TagBadge label={post.data.category} />
                )}
              </div>
              
              <div class="flex items-center gap-3 text-xs text-muted-foreground">
                <span class="flex items-center gap-1">
                  <Calendar size={12} />
                  {post.data.date}
                </span>
                <span class="flex items-center gap-1">
                  <Clock size={12} />
                  {post.data.readTime}
                </span>
              </div>
            </div>

              <h3 class="text-base mb-1 text-[rgb(var(--primary-blue))] group-hover:text-[rgb(var(--primary-purple))] transition-colors duration-200 ease-out font-semibold">
                {post.data.title}
              </h3>

            <p class="text-xs text-muted-foreground mb-2 line-clamp-1">
              {getPreview(post.body, 20)}
            </p>

            <div class="flex items-center justify-between">
              <span class="flex items-center gap-1 text-xs text-muted-foreground">
                <User size={12} />
                {post.data.author}
              </span>
              
              <span class="flex items-center gap-1 text-xs text-[rgb(var(--primary-blue))] group-hover:text-[rgb(var(--primary-purple))] transition-all duration-200 ease-out font-medium">
                Read More
                <ArrowRight size={12} class="group-hover:translate-x-1 transition-transform duration-200 ease-out" />
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>

    {blogPosts.length > 6 && (
      <div class="text-center mt-12">
        <a
          href="/blog"
          class="inline-block px-8 py-3 border border-[rgb(var(--primary-purple))] rounded-full hover:bg-[rgba(var(--primary-purple),0.10)] transition-all duration-200 ease-out hover:scale-105 active:scale-95 blog-cta"
        >
          View All Posts
        </a>
      </div>
    )}
  </div>
</section>

<script is:inline>
  if (typeof window !== 'undefined') {
    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view');
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    function setupObserver() {
      const section = document.querySelector('#blog .blog-container');
      if (section) {
        observer.observe(section);
      }
    }

    // Run on load and on astro page load
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', setupObserver);
    } else {
      setupObserver();
    }
    
    document.addEventListener('astro:page-load', setupObserver);
  }
</script>
