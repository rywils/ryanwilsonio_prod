---
import { skillData } from "../data/skillData";

const getSkills = (names: string[]) => {
  const all = skillData.flatMap((c) => c.skills);
  return names.map((name) => all.find((s) => s.name === name)).filter(Boolean);
};

const languageNames = [
  "TypeScript",
  "Python",
  "Go",
  "Rust",
  "C Programming",
  "C#",
  "PHP",
  "Bash",
];
const languages = getSkills(languageNames);

const cards = [
  {
    title: "Vulnerability Assessment",
    icon: "mdi:shield-search",
    accent: "#3b82f6",
    description:
      "Identifying attack surface through scanning, enumeration, and analysis of web apps, network services, and TLS configurations. Building Bitprobe for CVE detection and exposure mapping.",
    tools: getSkills(["Nmap", "Burpsuite", "Wireshark", "Snort", "Python"]),
  },
  {
    title: "Threat Detection",
    icon: "mdi:radar",
    accent: "#f59e0b",
    description:
      "Monitoring and correlating events across endpoints, networks, and cloud systems. Experience with SIEM pipelines, IDS tuning, and enterprise telemetry.",
    tools: getSkills(["Splunk", "Snort", "Kali Linux", "Linux/SELinux"]),
  },
  {
    title: "Incident Response",
    icon: "mdi:alarm-light",
    accent: "#ef4444",
    description:
      "Responding to incidents across enterprise environments—from endpoint compromise to infrastructure-level failures. Focused on containment and recovery.",
    tools: getSkills(["Splunk", "Linux/SELinux", "Bash", "Microsoft Windows"]),
  },
  {
    title: "Penetration Testing",
    icon: "mdi:lock-open-variant",
    accent: "#a855f7",
    description:
      "Offensive testing across web apps and networks—recon, exploitation, and reporting. Combining industry tools with custom tooling built in Go and Python.",
    tools: getSkills(["Kali Linux", "Burpsuite", "Metasploit", "Nmap", "Go"]),
  },
  {
    title: "Defense & Hardening",
    icon: "mdi:shield-lock",
    accent: "#22c55e",
    description:
      "Implementing layered defenses including NGFWs, network segmentation, endpoint protection, and hardened system configurations at enterprise scale.",
    tools: getSkills(["Fortinet", "Cisco", "Linux/SELinux", "Ansible", "WireGuard"]),
  },
  {
    title: "Web Application Security",
    icon: "mdi:web-check",
    accent: "#f43f5e",
    description:
      "Finding and exploiting web vulnerabilities—injection, auth flaws, IDOR, misconfigurations—through manual testing, code review, and automated scanning pipelines.",
    tools: getSkills(["Burpsuite", "Metasploit", "Snyk", "Go", "Python"]),
  },
  {
    title: "Network Engineering",
    icon: "mdi:lan",
    accent: "#06b6d4",
    description:
      "Designing and operating enterprise networks—routing, switching, VPNs, and segmentation across distributed multi-site environments.",
    tools: getSkills(["Cisco", "Juniper", "Aruba", "WireGuard", "Nmap"]),
  },
  {
    title: "Cloud & Infrastructure",
    icon: "mdi:cloud-outline",
    accent: "#f97316",
    description:
      "Building scalable cloud systems using infrastructure-as-code, containers, and hybrid environments across AWS, Azure, and GCP.",
    tools: getSkills(["AWS", "Azure", "Docker", "Terraform", "Ansible", "Kubernetes"]),
  },
  {
    title: "Web Development",
    icon: "mdi:code-braces",
    accent: "#ec4899",
    description:
      "Full-stack development from API design to production deployment. Secure, scalable systems with modern frameworks, authentication, and cloud-native architecture.",
    tools: getSkills(["Next.js", "React", "Svelte/Sveltekit", "Laravel", "Node.js", "tRPC"]),
  },
];

function cleanName(name: string) {
  return name
    .replace(" Programming", "")
    .replace("/SELinux", "")
    .replace("Svelte/Sveltekit", "Svelte")
    .replace("Microsoft Windows", "Windows");
}
---

<section id="skills" class="skills-section">

  <!-- ── Languages ── -->
  <div class="block-wrap">
    <h2 class="block-heading">Languages</h2>
    <div class="lang-grid">
      {languages.filter(Boolean).map((lang: any, i: number) => (
        <div class="lang-item" style={`animation-delay: ${i * 60}ms`}>
          <iconify-icon icon={lang.icon} class="lang-icon"></iconify-icon>
          <span class="lang-label">{cleanName(lang.name)}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- ── Cards ── -->
  <div class="block-wrap">
    <h2 class="block-heading">Security &amp; Engineering</h2>
    <div class="cards-grid">
      {cards.map((card, i) => (
        <div
          class="card"
          style={`--accent: ${card.accent}; animation-delay: ${i * 50}ms`}
        >
          <!-- glow blob -->
          <div class="card-glow"></div>

          <!-- header row -->
          <div class="card-header">
            <iconify-icon
              icon={card.icon}
              class="card-icon"
            ></iconify-icon>
            <h3 class="card-title">{card.title}</h3>
          </div>

          <p class="card-body">{card.description}</p>

          <!-- tool chips -->
          <div class="card-tools">
            {card.tools.filter(Boolean).map((tool: any) => (
              <span class={`tool-chip ${tool.colorClass ?? ""}`} title={tool.name}>
                <iconify-icon icon={tool.icon} class="tool-icon"></iconify-icon>
                <span class="tool-name">{cleanName(tool.name)}</span>
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>

</section>

<style>
  /* ─────────────────────────────────────────
     Section shell
  ───────────────────────────────────────── */
  .skills-section {
    width: 100%;
    max-width: 56rem;
    margin: 0 auto;
    padding: 3rem 1.5rem 4rem;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .block-wrap {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .block-heading {
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--primary-blue);
    letter-spacing: -0.01em;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  /* ─────────────────────────────────────────
     Language row
  ───────────────────────────────────────── */
  .lang-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem 2.5rem;
  }

  .lang-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.45rem;
    opacity: 0;
    animation: fadeUp 0.4s ease forwards;
    cursor: default;
  }

  .lang-icon {
    font-size: 2.4rem;
    line-height: 1;
    transition: transform 0.2s ease, filter 0.2s ease;
    filter: saturate(0.7);
  }

  .lang-item:hover .lang-icon {
    transform: translateY(-3px) scale(1.12);
    filter: saturate(1);
  }

  .lang-label {
    font-size: 0.7rem;
    letter-spacing: 0.03em;
    color: #6b7280;
    text-align: center;
    white-space: nowrap;
    transition: color 0.2s;
  }

  .lang-item:hover .lang-label {
    color: #d1d5db;
  }

  /* ─────────────────────────────────────────
     Cards grid
  ───────────────────────────────────────── */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  @media (max-width: 900px) {
    .cards-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* ─────────────────────────────────────────
     Individual card
  ───────────────────────────────────────── */
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    padding: 1.25rem 1.2rem 1.1rem;
    border-radius: 0.875rem;
    border: 1px solid rgba(255,255,255,0.07);
    background: rgba(255,255,255,0.025);
    overflow: hidden;
    opacity: 0;
    animation: fadeUp 0.4s ease forwards;
    transition:
      border-color 0.3s ease,
      background 0.3s ease,
      transform 0.2s ease,
      box-shadow 0.3s ease;
  }

  .card:hover {
    background: rgba(255,255,255,0.05);
    border-color: color-mix(in srgb, var(--accent) 45%, transparent);
    transform: translateY(-3px);
    box-shadow:
      0 8px 24px -8px color-mix(in srgb, var(--accent) 10%, transparent),
      0 0 0 0.5px color-mix(in srgb, var(--accent) 15%, transparent);
  }

  /* glow removed */
  .card-glow { display: none; }

  /* ── Card header ── */
  .card-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .card-icon {
    font-size: 1.35rem;
    color: var(--accent);
    opacity: 0.85;
    flex-shrink: 0;
    transition: opacity 0.2s, transform 0.2s;
  }

  .card:hover .card-icon {
    opacity: 1;
    transform: scale(1.1);
  }

  .card-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0;
    letter-spacing: -0.01em;
    line-height: 1.3;
    transition: filter 0.2s;
  }

  .card:hover .card-title {
    filter: brightness(1.2);
  }

  /* ── Card body ── */
  .card-body {
    font-size: 0.775rem;
    line-height: 1.6;
    color: #5a6472;
    margin: 0;
    flex: 1;
    transition: color 0.2s;
  }

  .card:hover .card-body { color: #6b7683; }

  /* ── Tool chips ── */
  .card-tools {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(255,255,255,0.05);
    margin-top: auto;
  }

  .tool-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.28rem;
    padding: 0.18rem 0.5rem 0.18rem 0.32rem;
    border-radius: 9999px;
    border: 1px solid rgba(255,255,255,0.07);
    background: rgba(255,255,255,0.04);
    font-size: 0.65rem;
    color: #6b7280;
    white-space: nowrap;
    cursor: default;
    transition:
      background 0.15s,
      border-color 0.15s,
      color 0.15s;
  }

  .tool-chip:hover {
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    border-color: color-mix(in srgb, var(--accent) 40%, transparent);
    color: #d1d5db;
  }

  .tool-icon {
    font-size: 0.85rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .tool-name {
    line-height: 1;
  }

  /* ─────────────────────────────────────────
     Animation
  ───────────────────────────────────────── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ─────────────────────────────────────────
     Responsive
  ───────────────────────────────────────── */
  @media (max-width: 640px) {
    .cards-grid { grid-template-columns: 1fr; }
    .lang-grid  { gap: 1.5rem 2rem; }
  }
</style>