---
import LucideIcon from '@/components/ui/LucideIcon.astro';
import { Image } from 'astro:assets';
import { iconPath } from '@/lib/icons';
import myBitmoji from '@/assets/bitmoji.webp';
import Encryptedtext from './Encryptedtext.astro';
import GradientBorder from './GradientBorder.astro';
import GlowCard from '@/components/ui/GlowCard.astro';
import HeroLamp from '@/components/ui/HeroLamp.astro';
import OrbitalTracer from './OrbitalTracer.astro';
const logos = [
  { icon: 'skill-icons:c', color: '#4d4ab4', x: 0, y: -117, startX: 930, startY: 0, startScale: 13.2, enterDelay: 0.4, floatDelay: 2 },
  { icon: 'skill-icons:rust', color: '#df372a', x: 91, y: -73, startX: 186, startY: 32, startScale: 12.2, enterDelay: 0.4, floatDelay: 1.6 },
  { icon: 'skill-icons:python-dark', color: '#ffd94a', x: 114, y: 26, startX: 1008, startY: 0, startScale: 12.2, enterDelay: 0.3, floatDelay: 3.2 },
  { icon: 'skill-icons:golang', color: '#00b4e0', x: 51, y: 105, startX: 930, startY: 0, startScale: 13.2, enterDelay: 0.2, floatDelay: 2.1 },
  { icon: 'skill-icons:php-dark', color: '#edeef0', x: -51, y: 105, startX: 1008, startY: 0, startScale: 12.2, enterDelay: 0.4, floatDelay: 1.5 },
  { icon: 'skill-icons:cs', color: '#953cad', x: -114, y: 26, startX: 218, startY: -16, startScale: 12.2, enterDelay: 0.2, floatDelay: 1.3 },
  { icon: 'skill-icons:elixir-dark', color: '#6a4d7a', x: -91, y: -73, startX: 1008, startY: 0, startScale: 12.2, enterDelay: 0.2, floatDelay: 2.1 },
];

const socialLinks = [
  { icon: iconPath('simple-icons:github'), link: 'https://github.com/rywils', label: 'GitHub', isImage: true },
  { icon: iconPath('simple-icons:linkedin'), link: 'https://linkedin.com/in/rywils', label: 'LinkedIn', isImage: true },
  { icon: iconPath('simple-icons:bluesky'), link: 'https://bsky.app/profile/ryanwilson.io', label: 'Bluesky', isImage: true },
  { link: 'mailto:ryan@ryanwilson.io', label: 'Email Ryan Wilson', isImage: false },
];


---

<div class="relative flex h-full w-full flex-col overflow-x-hidden border-b border-[#10191d] shadow-md shadow-[#0a0a0a] antialiased md:items-center pb-6 md:justify-center sm:overflow-visible">
  <div class="p-4 mx-auto relative z-10 w-full pt-10 md:pt-0">
    <section id="hero" class="hero-anim-pending flex flex-col justify-center relative py-6 overflow-visible max-md:overflow-x-hidden">
      <HeroLamp />

      <GlowCard variant="hero" class="hero-glow-card mt-10 max-w-4xl mx-auto max-md:w-full max-md:max-w-[min(42rem,calc(100vw-1.5rem))]">
        <div class="max-w-5xl mx-auto px-8 sm:px-12 lg:px-16 max-md:px-4 relative z-50 h-full flex justify-center">
          <div class="flex flex-col lg:flex-row justify-center gap-12 lg:gap-20 relative z-50 w-full max-w-5xl mx-auto p-4 max-md:p-2">

            <div class="flex justify-center flex-shrink-0 items-center">
              <div class="relative grid h-[216px] mt-12 md:mt-0 place-items-center sm:translate-x-0">
                <div class="relative z-20 grid h-[200px] w-[200px] place-items-center">
                  <Image
                    src={myBitmoji}
                    alt="Avatar"
                    width={200}
                    height={200}
                    widths={[200, 400]}
                    sizes="200px"
                    class="h-[200px] w-[200px] rounded-full border-4 border-[rgba(138,77,255,0.2)]"
                    loading="eager"
                    fetchpriority="high"
                    decoding="async"
                  />
                </div>

                <div class="pointer-events-none absolute left-1/2 top-1/2 z-99 h-0 w-0 -translate-x-1/2 -translate-y-1/2">
                  {logos.map((logo) => (
                    <span
                      class="skill"
                      style={`--glow:${logo.color}; --x:${logo.x}px; --y:${logo.y}px; --start-x:${logo.startX}px; --start-y:${logo.startY}px; --start-scale:${logo.startScale}; --enter-delay:${logo.enterDelay}s; --float-delay:${logo.floatDelay}s;`}
                    >
                      <img src={iconPath(logo.icon)} alt="" width="32" height="32" loading="lazy" decoding="async" />
                    </span>
                  ))}
                </div>
                <OrbitalTracer />
              </div>
            </div>

            <div class="text-center lg:text-left flex-1 max-w-2xl relative z-50">
              <h1
                data-hero-anim
                style="--hero-delay: 0.12s;"
                class="text-3xl sm:text-5xl mb-2 mt-6 font-bold text-[rgb(var(--primary-blue))] heading-font"
              >
                Ryan Wilson
              </h1>

<div class="flex justify-center lg:justify-start gap-4 max-md:flex-wrap max-md:gap-3 mt-4 font-mono text-sm uppercase tracking-widest">
  
  <span
    data-hero-anim
    style="--hero-delay: 0.46s;"
    class="px-3 pt-1.5 pb-1 border border-cyan-500/40 rounded-md hover:border-cyan-500/80 transition-colors duration-200 ease-out jetbrains-mono "
  >
    <Encryptedtext text="Software" />
</span>
<span
    data-hero-anim
    style="--hero-delay: 0.3s;"
    class="px-3 pt-1.5 pb-1 border border-pink-500/40 rounded-md hover:border-pink-500/80 transition-colors duration-200 ease-out jetbrains-mono"
  >
    <Encryptedtext text="Security"/>
  </span>

  <span
    data-hero-anim
    style="--hero-delay: 0.38s;"
    class="px-3 pt-1.5 pb-1 border border-purple-500/40 rounded-md hover:border-purple-500/80 transition-colors duration-200 ease-out jetbrains-mono"
  >
    <Encryptedtext text="Systems" />
  </span>
    
</div>

              <GradientBorder />
                            <p
                data-hero-anim
                style="--hero-delay: 0.56s;"
                class="text-sm leading-tight max-w-2xl mx-auto lg:mx-0 mb-18 text-muted-foreground jetbrains-mono"
              >
                Security-focused engineer with a background in networking, systems administration, full-stack development, and infrastructure operations.  
              </p>

              <div
                data-hero-anim
                style="--hero-delay: 0.66s;"
                class="btnAnimate mt-[-2.25rem] mb-10 flex w-full max-w-2xl flex-wrap justify-evenly gap-3 mx-auto lg:mx-0 max-md:mb-3"
              >
                <a
                  href="#contact"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="astra-contact-btn hero-cta"
                  id="hero-get-in-touch"
                >
                  <span class="astra-contact-btn__fill" aria-hidden="true"></span>
                  <span class="btnanimate relative z-10 inline-flex items-center gap-2">
                    Get In Touch 
                    <span class="btnAnimate ArrowAnimate"><LucideIcon name="arrow-right" size={18} /></span>
                  </span>
                </a>
              </div>
            </div>
          </div>
        </div>

        <div
          class="hero-socials absolute top-20 right-5 z-50 flex flex-col items-center gap-3 max-md:relative max-md:top-auto max-md:right-auto max-md:left-1/2 max-md:-translate-x-1/2 max-md:w-full max-md:flex-row max-md:justify-center max-md:gap-4 max-md:mt-3 max-md:pb-6"
          aria-label="Social links"
          style="--social-delay: 1.4s; --social-bounce-impact: -12px; --social-bounce-start: 84px; --social-bounce-rebound: 18px;"
        >
          {socialLinks.map(({ icon, link, label, isImage }) => (
            <div class="social__item">
              <a
                href={link}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={label}
                class="social__link flex h-8 w-8 items-center justify-center rounded-full border border-[rgb(var(--secondary-purple))] glow-primary-purple"
              >
                {isImage ? <span class="social-icon" style={`--icon-url: url(${icon});`}></span> : <LucideIcon name="mail" size={16} class="text-[rgb(var(--secondary-purple))]" />}
              </a>
            </div>
          ))}
        </div>
      </GlowCard>
    </section>
  </div>
</div>

<style>
/* Keep hero card border/glow inside the viewport on small screens */
@media (max-width: 767px) {
  :global(.hero-glow-card.glow-card-wrapper--hero) {
    overflow: hidden;
  }

  :global(.hero-glow-card .glow-card-glow) {
    inset: 0;
    filter: blur(16px);
  }
}

.btnAnimate{
  transition: transform 0.1s ease-in-out;
}

.btnAnimate:hover, .btnAnimate:focus-visible {
  transform: scale(1.05);
}

.ArrowAnimate {
  display: inline-flex;
  transition: transform 0.5s ease;
}

.astra-contact-btn:hover .ArrowAnimate,
.astra-contact-btn:focus-visible .ArrowAnimate {
  transform: rotate(90deg);
}
.skill {
  position: absolute;
  top: 0;
  left: 0;
  width: 42px;
  height: 42px;
  background: rgba(10,10,10,.9);
  border-radius: 10px;
  border: 1.5px solid var(--glow);
  box-shadow: 0 0 14px color-mix(in srgb, var(--glow) 65%, transparent);
  opacity: 0;
  transform: translate(-50%, -50%) translate(var(--x), var(--y));
  animation:
    skill-enter 1.58s cubic-bezier(0.18, 0.82, 0.25, 1) forwards var(--enter-delay),
    floating 5s ease-in-out var(--float-delay) infinite;
}

.skill img {
  width: 70%;
  height: 70%;
  margin: 15%;
}

.social-icon {
  width: 16px;
  height: 16px;
  display: inline-block;
  background-color: rgb(var(--secondary-purple));
  -webkit-mask-image: var(--icon-url);
  -webkit-mask-repeat: no-repeat;
  -webkit-mask-position: center;
  -webkit-mask-size: contain;
  mask-image: var(--icon-url);
  mask-repeat: no-repeat;
  mask-position: center;
  mask-size: contain;
}

/* Social link pop-on-hover  */
.social__link {
  display: inline-flex;
  transition: opacity 0.2s ease-out, transform 0.28s cubic-bezier(0.22, 1, 0.36, 1);
  transform: scale(1);
  transform-origin: center;
  will-change: transform;
}

.social__item:hover .social__link,
.social__item:focus-within .social__link {
  opacity: 1;
  transform: scale(1.1);
}

.social__link:not(:hover) {
  opacity: 0.92;
}

@keyframes bounce-in-left {
  0% {
    transform: translateX(-500px) scale(1);
    animation-timing-function: ease-in;
    opacity: 0;
  }
  38% {
    transform: translateX(0) scale(0.94);
    animation-timing-function: ease-out;
    opacity: 1;
  }
  55% {
    transform: translateX(-65px) scale(1.02);
    animation-timing-function: ease-in;
  }
  72% {
    transform: translateX(0) scale(0.96);
    animation-timing-function: ease-out;
  }
  81% {
    transform: translateX(-28px) scale(1.01);
    animation-timing-function: ease-in;
  }
  90% {
    transform: translateX(0) scale(0.98);
    animation-timing-function: ease-out;
  }
  95% {
    transform: translateX(-8px) scale(1.005);
    animation-timing-function: ease-in;
  }
  100% {
    transform: translateX(0) scale(1);
    animation-timing-function: ease-out;
  }
}

/* Mobile: rise into button underside (--social-bounce-impact), rebound down to rest (0) */
@keyframes bounce-in-bottom {
  0% {
    transform: translateY(var(--social-bounce-start, 84px)) scale(1);
    animation-timing-function: ease-in;
    opacity: 0;
  }
  38% {
    transform: translateY(var(--social-bounce-impact, -12px)) scale(0.94);
    animation-timing-function: ease-out;
    opacity: 1;
  }
  55% {
    transform: translateY(var(--social-bounce-rebound, 18px)) scale(1.02);
    animation-timing-function: ease-in;
  }
  72% {
    transform: translateY(0) scale(0.96);
    animation-timing-function: ease-out;
  }
  81% {
    transform: translateY(var(--social-bounce-rebound-small, 8px)) scale(1.01);
    animation-timing-function: ease-in;
  }
  90% {
    transform: translateY(0) scale(0.98);
    animation-timing-function: ease-out;
  }
  95% {
    transform: translateY(var(--social-bounce-rebound-tiny, 3px)) scale(1.005);
    animation-timing-function: ease-in;
  }
  100% {
    transform: translateY(0) scale(1);
    animation-timing-function: ease-out;
  }
}

/* Desktop: staggered bounce-in from the left */
@media (min-width: 768px) {
  .hero-socials {
    position: absolute;
    top: 5rem;
    right: 1.25rem;
    left: auto;
    width: auto;
    flex-direction: column;
    transform: none;
    margin: 0;
    padding: 0;
  }

  .hero-socials .social__item {
    animation: bounce-in-left 1.5s both;
  }

  .hero-socials .social__item:nth-child(1) {
    animation-delay: calc(var(--social-delay, 1.4s) + 0.2s);
  }

  .hero-socials .social__item:nth-child(2) {
    animation-delay: calc(var(--social-delay, 1.4s) + 0.35s);
  }

  .hero-socials .social__item:nth-child(3) {
    animation-delay: calc(var(--social-delay, 1.4s) + 0.5s);
  }

  .hero-socials .social__item:nth-child(4) {
    animation-delay: calc(var(--social-delay, 1.4s) + 0.65s);
  }
}

/* Mobile: wait for .hero-socials--ready so loader/metrics never desync icon 1 */
@media (max-width: 767px) {
  .hero-socials:not(.hero-socials--ready) .social__item {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    animation: none;
  }

  .hero-socials.hero-socials--ready .social__item {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    animation: bounce-in-bottom 1.5s both;
  }

  .hero-socials.hero-socials--ready .social__item:nth-child(1) {
    animation-delay: calc(var(--social-delay, 1.4s) + 0.2s);
  }

  .hero-socials.hero-socials--ready .social__item:nth-child(2) {
    animation-delay: calc(var(--social-delay, 1.4s) + 0.35s);
  }

  .hero-socials.hero-socials--ready .social__item:nth-child(3) {
    animation-delay: calc(var(--social-delay, 1.4s) + 0.5s);
  }

  .hero-socials.hero-socials--ready .social__item:nth-child(4) {
    animation-delay: calc(var(--social-delay, 1.4s) + 0.65s);
  }

  .hero-socials.hero-socials--ready .social__item .social__link {
    transition: opacity 0.2s ease-out;
  }
}

#hero.hero-anim-pending [data-hero-anim] {
  opacity: 0;
  transform: translateY(16px);
}

#hero.hero-anim-ready [data-hero-anim] {
  animation: heroTextEnter 0.62s cubic-bezier(0.22, 1, 0.36, 1) both;
  animation-delay: var(--hero-delay, 0s);
}

@keyframes heroTextEnter {
  from {
    opacity: 0;
    transform: translateY(16px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@media (prefers-reduced-motion: reduce) {
  .social__link,
  .hero-socials .social__item {
    animation: none !important;
    opacity: 1 !important;
    transform: none;
  }

  .skill {
    animation: none !important;
    opacity: 1 !important;
    filter: none !important;
    transform: translate(-50%, -50%) translate(var(--x), var(--y)) scale(1) !important;
  }

  #hero.hero-anim-pending [data-hero-anim],
  #hero.hero-anim-ready [data-hero-anim] {
    animation: none !important;
    opacity: 1 !important;
    transform: none !important;
  }
}

@keyframes skill-enter {
  0% {
    opacity: 0;
    transform:
      translate(-50%, -50%)
      translate(var(--x), var(--y))
      translate(var(--start-x), var(--start-y))
      scale(var(--start-scale));
  }
  18% {
    opacity: 0.35;
  }
  100% {
    opacity: 1;
    transform:
      translate(-50%, -50%)
      translate(var(--x), var(--y))
      scale(1);
  }
}

@keyframes floating {
  0%, 100% { translate: 0 0; }
  50% { translate: 0 -6px; }
}

.astra-contact-btn {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0.5rem 2rem;
  border-radius: 0.5rem;
  border: 1px solid rgb(var(--primary-blue));
  color: rgb(var(--primary-blue));
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  overflow: hidden;
  isolation: isolate;
  background: transparent;
  transition:
    color 0.25s ease-out,
    box-shadow 0.25s ease-out,
    transform 0.2s ease-out,
    letter-spacing 0.35s ease-out;
  --fill-x: 50%;
  --fill-y: 50%;
  --cta-color: rgb(var(--primary-blue));
  --cta-shadow: rgba(0, 191, 255, 0.45);
}

.astra-contact-btn--secondary {
  --cta-color: rgb(var(--secondary-purple));
  --cta-shadow: rgba(var(--secondary-purple), 0.42);
}

.astra-contact-btn--github {
  --cta-color: #F98A3C;
  --cta-shadow: rgba(249, 138, 60, 0.42);
}

.astra-contact-btn {
  border-color: var(--cta-color);
  color: var(--cta-color);
}

.astra-contact-btn:hover,
.astra-contact-btn:focus-visible {
  color: #fff;
  box-shadow: 0 0 30px 5px var(--cta-shadow);
  transform: scale(1.04);
  letter-spacing: 0.2em;
}

.astra-contact-btn:active {
  transform: scale(0.98);
  box-shadow: none;
}

.astra-contact-btn__fill {
  display: block;
  position: absolute;
  top: var(--fill-y);
  left: var(--fill-x);
  width: 16px;
  height: 16px;
  border-radius: 9999px;
  background: var(--cta-color);
  transform: translate(-50%, -50%) scale(0);
  transform-origin: center;
  z-index: 0;
  transition: transform 0.45s ease-out;
}

.astra-contact-btn:hover .astra-contact-btn__fill,
.astra-contact-btn:focus-visible .astra-contact-btn__fill {
  transform: translate(-50%, -50%) scale(24);
}
</style>

<script is:inline>
  function initHeroTextAnimations() {
    const hero = document.getElementById("hero");
    if (!hero || hero.dataset.heroAnimBound === "1") return;
    hero.dataset.heroAnimBound = "1";

    const reveal = () => {
      hero.classList.remove("hero-anim-pending");
      hero.classList.add("hero-anim-ready");
    };

    requestAnimationFrame(reveal);
  }

  function updateSocialBounceMetrics() {
    if (window.matchMedia("(min-width: 768px)").matches) return;
    var btn = document.getElementById("hero-get-in-touch");
    var socials = document.querySelector("#hero .hero-socials");
    if (!btn || !socials) return;

    var gap = socials.getBoundingClientRect().top - btn.getBoundingClientRect().bottom;
    if (gap < 0) gap = 0;
    var impact = -Math.round(gap);
    var start = Math.round(gap + 72);
    var rebound = Math.max(14, Math.round(gap * 0.85 + 10));

    socials.style.setProperty("--social-bounce-impact", impact + "px");
    socials.style.setProperty("--social-bounce-start", start + "px");
    socials.style.setProperty("--social-bounce-rebound", rebound + "px");
    socials.style.setProperty("--social-bounce-rebound-small", Math.round(rebound * 0.45) + "px");
    socials.style.setProperty("--social-bounce-rebound-tiny", Math.max(2, Math.round(rebound * 0.15)) + "px");
  }

  function startMobileSocialEntrance() {
    if (window.matchMedia("(min-width: 768px)").matches) return;
    var socials = document.querySelector("#hero .hero-socials");
    if (!socials || socials.dataset.entranceStarted === "1") return;

    function launch() {
      if (socials.dataset.entranceStarted === "1") return;
      socials.dataset.entranceStarted = "1";
      updateSocialBounceMetrics();
      socials.classList.add("hero-socials--ready");
    }

    launch();
  }

  function initMobileSocialEntrance() {
    if (!document.getElementById("hero")) return;

    startMobileSocialEntrance();

    if (window.__rwMobileSocialEntrance) return;
    window.__rwMobileSocialEntrance = true;

    /* Do not strip hero-socials--ready here — astro:page-load also fires on first
       paint and was making icons fade out after they landed. Fresh hero DOM on
       client navigations has no --ready / entranceStarted yet. */
    document.addEventListener("astro:page-load", startMobileSocialEntrance);
  }

  function initAstracontactButton() {
    document.querySelectorAll(".astra-contact-btn").forEach((btn) => {
      if (btn.dataset.astraBound === "1") return;
      btn.dataset.astraBound = "1";

      const updateFillOrigin = (event) => {
        const rect = btn.getBoundingClientRect();
        const x = ((event.clientX - rect.left) / rect.width) * 100;
        const y = ((event.clientY - rect.top) / rect.height) * 100;
        btn.style.setProperty("--fill-x", `${x}%`);
        btn.style.setProperty("--fill-y", `${y}%`);
      };

      btn.addEventListener("pointerenter", updateFillOrigin);
      btn.addEventListener("pointermove", updateFillOrigin);
    });
  }

  initHeroTextAnimations();
  document.addEventListener("astro:page-load", initHeroTextAnimations);
  initMobileSocialEntrance();
  initAstracontactButton();
  document.addEventListener("astro:page-load", initAstracontactButton);
</script>