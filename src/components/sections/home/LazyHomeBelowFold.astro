---
/** Placeholder; Projects/Blog/Contact HTML loads on idle or when near viewport. */
---

<div
  id="home-below-fold"
  class="home-below-fold-pending min-h-[480px]"
  data-partial-src="/partials/home-below-fold.html"
  aria-busy="true"
>
  <div class="mx-auto max-w-5xl px-6 py-16 text-center text-sm text-gray-500">
    Loading projects and posts…
  </div>
</div>

<script is:inline>
  (function () {
    var mount = document.getElementById("home-below-fold");
    if (!mount || mount.dataset.bound === "1") return;
    mount.dataset.bound = "1";

    var src = mount.getAttribute("data-partial-src");
    if (!src) return;

    var loaded = false;
    function loadPartial() {
      if (loaded) return;
      loaded = true;
      fetch(src, { credentials: "same-origin" })
        .then(function (res) {
          if (!res.ok) throw new Error("partial " + res.status);
          return res.text();
        })
        .then(function (html) {
          var doc = new DOMParser().parseFromString(html, "text/html");
          var body = doc.body;
          mount.replaceWith.apply(mount, Array.from(body.childNodes));

          function activateScript(oldScript) {
            if (oldScript.dataset.activated === "1") return;
            var script = document.createElement("script");
            Array.from(oldScript.attributes).forEach(function (attr) {
              script.setAttribute(attr.name, attr.value);
            });
            script.textContent = oldScript.textContent;
            oldScript.replaceWith(script);
          }

          var main = document.getElementById("main-content");
          if (main) {
            var inPartial = false;
            Array.from(main.children).forEach(function (child) {
              if (child.id === "projects") inPartial = true;
              if (!inPartial) return;
              if (child.tagName === "SCRIPT") activateScript(child);
            });
          }

          document.dispatchEvent(new CustomEvent("astro:page-load"));
        })
        .catch(function () {
          mount.innerHTML =
            '<p class="px-6 py-16 text-center text-sm text-gray-500">Could not load section. <a href="/projects" class="text-[rgb(var(--primary-blue))] underline">View projects</a></p>';
          mount.removeAttribute("aria-busy");
        });
    }

    if ("IntersectionObserver" in window) {
      var io = new IntersectionObserver(
        function (entries) {
          if (!entries.some(function (e) { return e.isIntersecting; })) return;
          io.disconnect();
          loadPartial();
        },
        { rootMargin: "320px 0px" }
      );
      io.observe(mount);
    }

    if ("requestIdleCallback" in window) {
      requestIdleCallback(loadPartial, { timeout: 2500 });
    } else {
      setTimeout(loadPartial, 1200);
    }
  })();
</script>
