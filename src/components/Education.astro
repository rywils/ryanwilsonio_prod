---
import wguIcon from '../assets/wgu.png';
import dmaccIcon from '../assets/dmaccfit.png';
import { Image } from 'astro:assets';
import Certifications from './Certifications.astro';

const education = [
  {
    degree: 'Bachelor of Science in Cybersecurity and Information Assurance',
    institution: 'Western Governors University',
    period: 'In Progress — Started January 2026',
    description: '',
    icon: wguIcon,
  },
  {
    degree: 'A.A.S. Information Technology — Network Administration',
    institution: 'Des Moines Area Community College',
    period: 'Graduated May 2016',
    description: '',
    icon: dmaccIcon,
  },
];
---

<section id="education" class="relative overflow-hidden pt-12 pb-12">

  <div class="max-w-5xl mx-auto relative z-10 education-container">

    <h2 class="education-title text-2xl sm:text-3xl font-semibold mb-2 text-[rgb(var(--primary-blue))]">
      Education
    </h2>

    <div
      class="education-underline h-0.5 rounded-full
      bg-gradient-to-r from-[rgb(var(--primary-blue))] to-[rgb(var(--primary-purple))]
      mb-8 max-w-[5rem]"
      aria-hidden="true"
    />

    <div class="grid md:grid-cols-2 gap-6 mb-14">

      {education.map((item, index) => (
        <div
         class="education-card p-6 rounded-xl bg-gradient-to-br from-[rgba(10,10,20,0.8)] to-[rgba(18,12,30,0.9)]
         border border-[rgba(var(--primary-blue),0.25)] shadow-md hover:border-[rgba(var(--primary-blue),0.50)] 
         hover:shadow-[0_0_25px_rgba(0,191,255,0.15)] flex gap-4 items-start h-full min-h-[220px] group
         transition-[background-color,border-color,box-shadow,transform] duration-300 ease-out hover:-translate-y-[2px]"

          style={`--edu-delay: ${0.2 + index * 0.1}s`}
        >

          <div class="flex-shrink-0 w-12 h-12 rounded-lg overflow-hidden
          border border-white/10
          group-hover:border-[rgba(var(--primary-purple),0.40)]
          bg-transparent">

            <Image
              src={item.icon}
              alt={item.institution}
              width={64}
              height={64}
              class="w-full h-full object-contain"
            />
          </div>

          <div class="flex-1 flex flex-col justify-start">

            <h4 class="mb-1 font-semibold text-[rgb(var(--primary-blue))]
            group-hover:text-[rgb(var(--primary-purple))]
            transition-[color] duration-200 ease-out">
              {item.degree}
            </h4>

            <p class="text-sm text-neutral-400">
              {item.institution}
            </p>

            <p class="text-xs text-neutral-500 mt-1">
              {item.period}
            </p>

            <p class="text-sm text-neutral-400 mt-2">
              {item.description}
            </p>

          </div>
        </div>
      ))}

    </div>

    <Certifications />

  </div>
</section>