---
import wguIcon from '../assets/wgu.png';
import dmaccIcon from '../assets/dmaccfit.png';
import { Image } from 'astro:assets';
import Certifications from './Certifications.astro';

const education = [

  {
    degree: 'Bachelor of Science in Cybersecurity and Information Assurance',
    institution: 'Western Governors University',
    period: '01/2026',
    description: '',
    icon : wguIcon,
  },
  {
    degree: 'Associate of Applied Science in Information Technology Network Administration',
    institution: 'Des Moines Area Community College',
    period: '2014 - 2016',
    description: 'Linux emphasis',
    icon: dmaccIcon,
  },
];
---

<section id="education" class="relative overflow-hidden pt-12 pb-12">

  <div class="max-w-5xl mx-auto relative z-10 education-container">
    <h2 class="education-title text-2xl sm:text-3xl font-semibold mb-2 text-(--primary-blue)">Education</h2>
    <div
      class="education-underline h-0.5 rounded-full bg-gradient-to-r from-(--primary-blue) to-(--primary-purple) mb-8 max-w-[5rem]"
      aria-hidden="true"
    />
    <div class="grid md:grid-cols-2 gap-6 mb-14">
      {education.map((item, index) => (
        <div
          class="education-card p-6 rounded-xl bg-gradient-to-br from-(--primary-blue)/10 to-(--secondary-purple)/10 border border-(--primary-blue)/30 hover:border-(--primary-purple)/30 flex gap-4 items-start h-full min-h-[220px] group"
          style={`--edu-delay: ${0.2 + index * 0.1}s`}
        >
          <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-white overflow-hidden border border-(--primary-blue)/40 group-hover:border-(--primary-purple)/40 bg-transparent">
            <Image src={item.icon} alt={item.institution} width={64} height={64} class="w-full h-full object-contain" />
          </div>
          <div class="flex-1 flex flex-col justify-start">
            <h4 class="mb-1 font-semibold text-(--primary-blue) group-hover:text-(--primary-purple)">{item.degree}</h4>
            <p class="text-sm text-muted-foreground">{item.institution}</p>
            <p class="text-xs text-muted-foreground mt-1">{item.period}</p>
            <p class="text-sm text-muted-foreground mt-2">{item.description}</p>
          </div>
        </div>
      ))}
    </div>


    <Certifications />
    <!-- <div class="grid md:grid-cols-2 gap-6">
      {certifications.map((cert, index) => (
        <div
          class="certification-card p-6 rounded-xl bg-gradient-to-br from-(--primary-blue)/10 to-(--secondary-purple)/10 border border-(--primary-blue)/30 hover:border-(--primary-purple)/30 flex gap-4 items-start h-full min-h-[180px] group"
          style={`--cert-delay: ${0.2 + index * 0.1}s`}
        >
          <div class="flex-shrink-0 w-12 h-12 rounded-lg overflow-hidden border border-(--primary-blue)/40 bg-transparent">
            <Image src={cert.icon} alt={cert.issuer} width={64} height={64} class="w-full h-full object-cover" />
          </div>
          <div class="flex-1 flex flex-col justify-start">
            <h4 class="mb-1 font-semibold text-(--primary-blue) group-hover:text-(--primary-purple)">{cert.name}</h4>
            <p class="text-sm text-muted-foreground">{cert.issuer}</p>
            <p class="text-xs text-muted-foreground mt-1">{cert.date}</p>
          </div>
        </div>
      ))}
    </div> -->
  </div>
</section>
