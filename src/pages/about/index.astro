---
import Layout from "../../layouts/Layout.astro";
import me from "../../assets/me.png";
import WorkExperience from "@/components/WorkExperience.astro";
import Education from "@/components/Education.astro";
import SkillsSection from "@/components/SkillsSection.astro";
---

<Layout title="About Me" description="About me page. Skills, work history, and what I do outside of tech.">

  <div class="relative flex h-full w-full flex-col overflow-x-hidden border-b border-[#10191d] shadow-md shadow-[#0a0a0a] antialiased md:items-center md:justify-center sm:overflow-visible">
    <div class="p-4 mx-auto relative z-10 w-full pt-10 md:pt-0">

      <section id="aboutme" class="flex flex-col justify-center relative py-6 overflow-visible">
        <div class="about-container mx-auto w-full max-w-5xl px-4 pt-16 text-gray-300">
          <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8 mb-5">
            <img
              src={me.src ?? me}
              alt="Ryan Wilson"
              class="about-image md:hidden h-32 w-32 rounded-full object-cover border border-white/10 shadow-xl opacity-90 hover:opacity-100 transition"
            />
            <div class="flex-1 min-w-0">
              <h1 class="about-title text-4xl font-bold mb-2 text-(--primary-blue)">About Me</h1>
              <div
                class="about-underline h-0.5 rounded-full bg-gradient-to-r from-(--primary-blue) to-(--primary-purple) mb-6"
                aria-hidden="true"
              />
              <p class="about-text text-lg leading-relaxed text-gray-400 max-w-2xl">
                I'm a network engineer, full-stack developer, and cybersecurity student focused on
                building secure, scalable, high-performance systems. My background spans network and systems engineering,
                application development, infrastructure, and cloud platforms. I bring a security-first mindset
                to everything I build.
              </p>
            </div>
            <img
              src={me.src ?? me}
              alt="Ryan Wilson"
              class="about-image hidden md:inline-block h-32 w-32 md:h-40 md:w-40 rounded-full object-cover border-3 border-(--primary-blue)/60 hover:border-(--primary-purple)/60 shadow-xl opacity-90 hover:opacity-100 transition shrink-0"
            />
          </div>
        </div>
      </section>

    </div>
  </div>

  <SkillsSection />

  <div class="border-b-1 border-[#10191d] shadow-md shadow-[#0a0a0a]">
    <div class="mx-auto max-w-4xl px-6 py-12 text-gray-300">

      <WorkExperience />
      <Education />

      <div class="outside-tech-reveal slide-blur-up mt-12">
        <h2 class="text-2xl font-semibold mb-6 text-(--primary-blue)">Outside of Tech</h2>
        <p class="text-lg text-gray-400">
          Outside of tech I enjoy spending time with friends, pool league, photography, and spontaneous road trips.
        </p>
      </div>

      <script is:inline>
        (function () {
          function initAboutScrollAnimations() {
            var selectors = [
              ".about-container",
              ".skills-container",
              ".experience-container",
              "#education .education-container",
              ".outside-tech-reveal",
              ".certifications-reveal",
            ].join(", ");
            var opts = { threshold: 0.12, rootMargin: "0px 0px -32px 0px" };
            var nodes = document.querySelectorAll(selectors);
            if (!nodes.length) return;
            var observer = new IntersectionObserver(function (entries) {
              entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                  entry.target.classList.add("in-view");
                  observer.unobserve(entry.target);
                }
              });
            }, opts);
            nodes.forEach(function (el) {
              if (!el.classList.contains("in-view")) observer.observe(el);
            });
          }
          document.addEventListener("DOMContentLoaded", initAboutScrollAnimations);
          document.addEventListener("astro:page-load", initAboutScrollAnimations);
        })();
      </script>

    </div>
  </div>

</Layout>
