---
import Layout from "@/layouts/Layout.astro";
import me from "@/assets/me.webp";
import WorkExperience from "@/components/sections/about/WorkExperience.astro";
import Education from "@/components/sections/about/Education.astro";
import SkillsSection from "@/components/sections/about/SkillsSection.astro";
import Heading from "@/components/ui/Heading.astro";
---

<Layout title="About Me" description="About page">
  <div class="relative flex h-full w-full flex-col overflow-x-hidden border-b border-[#10191d] shadow-md shadow-[#0a0a0a] antialiased md:items-center md:justify-center sm:overflow-visible">
    <div class="p-4 mx-auto relative z-10 w-full pt-10 md:pt-0">

      <section id="aboutme" class="flex flex-col justify-center relative py-6 overflow-visible">
        <div class="about-container mx-auto w-full max-w-4xl px-6 pt-16 text-gray-300">
          <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8 mb-5">
            <img
              src={me.src ?? me}
              alt="Ryan Wilson"
              class="about-image md:hidden h-32 w-32 rounded-full object-cover border border-white/10 shadow-xl opacity-90 hover:opacity-100 transition"
            />
            <div class="flex-1 min-w-0">
              <Heading size="md" className="about-title mb-2">About Me</Heading>
              <div
                class="about-underline h-[2px] mt-4 rounded-full bg-gradient-to-r from-[rgb(var(--primary-blue))] to-[rgb(var(--primary-purple))] mb-6"
                aria-hidden="true"
              />
              <p class="about-text text-lg leading-relaxed text-gray-400 max-w-2xl">
                Security-focused engineer specialized in enterprise networking, linux systems, cloud environments, and web applications. Currently pursuing a B.S. in Cybersecurity and Information Assurance. Currently working as a Senior Infrastructure Engineer @ AGIS Global. I have a passion for learning and exploring new technologies, and I enjoy sharing my knowledge with others through writing and mentoring. In my free time, I enjoy photography, pool league, and spontaneous road trips.
              </p>
            </div>
            <img
              src={me.src ?? me}
              alt="Ryan Wilson"
              class="about-image hidden md:inline-block h-32 w-32 md:h-40 md:w-40 rounded-full object-cover border-3 border-[rgba(var(--primary-blue),0.60)] hover:border-[rgba(var(--primary-purple),0.60)] shadow-xl opacity-90 hover:opacity-100 transition shrink-0"
            />
          </div>
        </div>
      </section>

    </div>
  </div>

  <SkillsSection />

  <div class="border-b-1 border-[#10191d] shadow-md shadow-[#0a0a0a]">
    <div class="mx-auto max-w-4xl px-6 py-12 text-gray-300">

      <WorkExperience />
      <Education />

      <script is:inline>
        (function () {
          function initAboutScrollAnimations() {
            var selectors = [
              ".about-container",
              ".skills-container",
              ".experience-container",
              "#education .education-container",
              ".outside-tech-reveal",
              ".certifications-reveal",
            ].join(", ");
            var opts = { threshold: 0.12, rootMargin: "0px 0px -32px 0px" };
            var nodes = document.querySelectorAll(selectors);
            if (!nodes.length) return;
            var observer = new IntersectionObserver(function (entries) {
              entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                  entry.target.classList.add("in-view");
                  observer.unobserve(entry.target);
                }
              });
            }, opts);
            nodes.forEach(function (el) {
              if (!el.classList.contains("in-view")) observer.observe(el);
            });
          }
          document.addEventListener("DOMContentLoaded", initAboutScrollAnimations);
          document.addEventListener("astro:page-load", initAboutScrollAnimations);
        })();
      </script>

    </div>
  </div>

</Layout>
