---

import Layout from '../../layouts/Layout.astro';
import { ArrowLeft, ExternalLink, Github } from 'lucide-react';
import { getCollection, render } from 'astro:content';
import LangBadge from '@/components/ui/LangBadge.astro';
import ProjectImage from '@/components/ProjectImage.astro';
import { getGitHubReadmeHtml } from '@/lib/githubReadme';
import { shouldUseLocalProjectBody } from '@/lib/projectContent';

export const prerender = true;

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { id: project.id.replace(/\.md$/, '') },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content: ProjectContent } = await render(project);

const useLocalBody = shouldUseLocalProjectBody(project.data.overwrite, project.data.github);

let readmeHtml: string | null = null;
if (!useLocalBody && project.data.github) {
  try {
    readmeHtml = await getGitHubReadmeHtml(project.data.github);
  } catch (e) {
    console.error(`Failed to fetch README for ${project.data.github}:`, e);
  }
}

const showGitHubReadme = !useLocalBody && Boolean(readmeHtml?.trim());
---

<Layout title={`${project.data.title} - Ryan Wilson`}>
  <article class="project-detail pt-24 pb-20 px-4 sm:px-6 lg:px-8 relative overflow-hidden min-h-screen">
    
    <div class="max-w-5xl mx-auto relative z-10">
      
      <a 
        href="/projects"
        class="inline-flex items-center gap-2 text-[rgb(var(--primary-blue))] hover:text-[rgb(var(--primary-purple))] transition-all duration-200 ease-out mb-8 group"
        data-astro-prefetch
      >
        <ArrowLeft className="group-hover:-translate-x-1 transition-transform duration-200 ease-out" size={20} />
        <span class="font-semibold">Back to Projects</span>
      </a>

      
      <div class="relative overflow-hidden rounded-2xl mb-8 aspect-video border border-[rgba(var(--primary-blue),0.20)]">
        <ProjectImage
          src={project.data.image}
          alt={project.data.title}
          class="w-full h-full object-cover"
          variant="hero"
        />
      </div>

      
      <div class="mb-8">
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-[rgb(var(--primary-purple))] mb-4">
          {project.data.title}
        </h1>
        
        <div class="flex flex-wrap gap-2 mb-6">
  {project.data.tags.map(tag => (
    <LangBadge
      variant={tag as any}
      class="opacity-90"
    />
  ))}
</div>


        
        <div class="flex flex-wrap gap-4">
          {project.data.github && (
            <a 
              href={project.data.github}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm rounded-sm bg-[rgba(var(--primary-blue),0.20)] border border-[rgb(var(--primary-blue))] text-[rgb(var(--primary-blue))] hover:bg-[rgba(var(--primary-blue),0.30)] transition-all duration-200 ease-out hover:scale-105 active:scale-95 font-medium"
            >
              <Github size={16} />
              View Code
            </a>
          )}
          {project.data.demo && project.data.demo !== project.data.github && (
            <a 
              href={project.data.demo}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-[rgba(var(--secondary-purple),0.20)] border border-[rgb(var(--secondary-purple))] text-[rgb(var(--secondary-purple))] hover:bg-[rgba(var(--secondary-purple),0.30)] transition-all duration-200 ease-out hover:scale-105 active:scale-95 font-semibold"
            >
              <ExternalLink size={20} />
              Live Demo
            </a>
          )}
        </div>
      </div>

      
      
      {showGitHubReadme ? (
        <div class="prose prose-invert max-w-none space-y-8 text-muted-foreground markdown-content" set:html={readmeHtml} />
      ) : (
        <div class="prose prose-invert max-w-none space-y-8 text-muted-foreground markdown-content">
          <ProjectContent />
        </div>
      )}

      
      {project.data.technologies && project.data.technologies.length > 0 && (
        <section class="mt-8">
          <h2 class="text-lg font-semibold text-[rgb(var(--primary-blue))] mb-3">Technologies Used</h2>
          <div class="flex flex-wrap gap-2">
            {project.data.technologies.map(tech => (
              <span class="px-2 py-0.5 text-xs rounded-sm bg-[rgba(var(--primary-purple),0.10)] border border-[rgba(var(--primary-purple),0.30)] font-medium">
                {tech}
              </span>
            ))}
          </div>
        </section>
      )}

      
      <div class="mt-16 pt-8 border-t border-[rgba(var(--primary-blue),0.20)]">
        <a 
          href="/projects"
          class="inline-flex items-center gap-2 text-[rgb(var(--primary-blue))] hover:text-[rgb(var(--primary-purple))] transition-all duration-200 ease-out group font-semibold text-lg"
          data-astro-prefetch
        >
          <ArrowLeft class="group-hover:-translate-x-1 transition-transform duration-200 ease-out" size={24} />
          <span>View All Projects</span>
        </a>
      </div>
    </div>
  </article>
</Layout>

<style>
  .markdown-content :global(h1) {
    font-size: 2.25rem;
    font-weight: 700;
    color: rgb(var(--primary-purple));
    margin-bottom: 1rem;
    margin-top: 2.5rem;
  }

  .markdown-content :global(h2) {
    font-size: 1.875rem;
    font-weight: 600;
    color: rgb(var(--primary-blue));
    margin-bottom: 1rem;
    margin-top: 2rem;
  }

  .markdown-content :global(h3) {
    font-size: 1.5rem;
    font-weight: 600;
    color: rgb(var(--primary-blue));
    margin-bottom: 0.75rem;
    margin-top: 1.5rem;
  }
  
  .markdown-content :global(p) {
    font-size: 1.125rem;
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  .markdown-content :global(table) {
    display: block;
    width: 100%;
    max-width: 100%;
    margin: 1.5rem 0;
    overflow-x: auto;
    border-collapse: collapse;
    border: 1px solid rgba(var(--primary-blue), 0.18);
    border-radius: 0.75rem;
  }

  .markdown-content :global(thead) {
    background: rgba(var(--primary-blue), 0.10);
  }

  .markdown-content :global(th),
  .markdown-content :global(td) {
    padding: 0.9rem 1rem;
    border-bottom: 1px solid rgba(var(--primary-blue), 0.14);
    text-align: left;
    vertical-align: top;
    overflow-wrap: anywhere;
  }

  .markdown-content :global(th) {
    color: rgb(var(--primary-blue));
    font-weight: 700;
    white-space: nowrap;
  }

  .markdown-content :global(td) {
    min-width: 9rem;
  }

  .markdown-content :global(td code) {
    white-space: normal;
    overflow-wrap: anywhere;
  }

  .markdown-content :global(tr:last-child td) {
    border-bottom: 0;
  }

  .markdown-content :global(ul) {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin: 1rem 0;
  }

  .markdown-content :global(li) {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .markdown-content :global(li::before) {
    content: "▹";
    color: rgb(var(--primary-purple));
    font-size: 1.25rem;
    margin-top: 0.25rem;
    flex-shrink: 0;
  }

  .markdown-content :global(strong) {
    color: rgb(var(--primary-purple));
    font-weight: 600;
  }

  .markdown-content :global(a) {
    color: rgb(var(--primary-blue));
    text-decoration: underline;
    transition: color 0.2s;
  }

  .markdown-content :global(a:hover) {
    color: rgb(var(--primary-purple));
  }
</style>
